# Copy this file to .env. Never commit the populated .env file.
ENV=production
DATABASE_URL=sqlite+aiosqlite:////data/shijian.db

# Generate with: python -c "import secrets; print(secrets.token_urlsafe(48))"
JWT_SECRET=replace-with-a-random-secret

# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
API_KEY_ENCRYPTION_KEY=replace-with-64-hex-characters

CORS_ALLOW_ORIGINS=http://localhost:8000,http://localhost:5173
BASE_URL=http://localhost:8000
MAX_CONCURRENT_RUNS=10

# Optional email. The old QQ authorization code was revoked and is not included.
QQ_ALERT_EMAIL=
QQ_SMTP_USER=
QQ_SMTP_AUTH_CODE=
QQ_SMTP_HOST=smtp.qq.com
QQ_SMTP_PORT=587
